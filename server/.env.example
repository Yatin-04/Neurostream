PORT=3001
ALLOWED_ORIGINS=http://localhost:5173
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/neurostream

# JWT
JWT_SECRET=change-me-in-production

# SMTP (use Mailtrap for dev)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="NeuroStream" <noreply@neurostream.dev>

# TURN (optional)
METERED_TURN_URL=
METERED_TURN_USERNAME=
METERED_TURN_CREDENTIAL=
